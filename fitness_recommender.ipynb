    "# Step 1: Dataset Generation\n",
    "# Create synthetic data to train the model since real fitness data may not be available\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import random\n",
    "\n",
    "# Set random seed for reproducible results\n",
    "np.random.seed(42)\n",
    "random.seed(42)\n",
    "\n",
    "# Define possible categories for categorical features\n",
    "goals = ['lose_weight', 'gain_muscle', 'maintain']  # User's fitness goals\n",
    "activities = ['low', 'medium', 'high']  # User's activity levels\n",
    "workouts = ['cardio', 'strength', 'mixed', 'rest_light']  # Target workout types\n",
    "\n",
    "# Generate 2000 synthetic samples for better model training\n",
    "n_samples = 2000\n",
    "\n",
    "# Randomly generate features within realistic ranges\n",
    "data = {\n",
    "    'age': np.random.randint(18, 71, n_samples),  # Age 18-70\n",
    "    'weight': np.random.uniform(50, 120, n_samples).round(1),  # Weight 50-120 kg\n",
    "    'height': np.random.uniform(150, 200, n_samples).round(1),  # Height 150-200 cm\n",
    "    'goal': [random.choice(goals) for _ in range(n_samples)],  # Random goal\n",
    "    'activity_level': [random.choice(activities) for _ in range(n_samples)],  # Random activity\n",
    "}\n",
    "\n",
    "# Create DataFrame\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# Define logic to assign workout based on features (simulates expert knowledge)\n",
    "def assign_workout(row):\n",
    "    age, weight, height, goal, activity = row['age'], row['weight'], row['height'], row['goal'], row['activity_level']\n",
    "    bmi = weight / ((height / 100) ** 2)  # Calculate BMI\n",
    "    \n",
    "    if goal == 'lose_weight':\n",
    "        if bmi > 25:  # Overweight\n",
    "            return 'cardio'  # Cardio for fat loss\n",
    "        elif activity == 'high':\n",
    "            return 'mixed'  # Mix if active\n",
    "        else:\n",
    "            return 'rest_light'  # Light if low activity\n",
    "    elif goal == 'gain_muscle':\n",
    "        if age < 35 and activity in ['medium', 'high']:  # Young and active\n",
    "            return 'strength'  # Strength training\n",
    "        elif activity == 'high':\n",
    "            return 'mixed'\n",
    "        else:\n",
    "            return 'rest_light'\n",
    "    elif goal == 'maintain':\n",
    "        if activity == 'high':\n",
    "            return 'mixed'\n",
    "        elif activity == 'medium':\n",
    "            return 'strength'\n",
    "        else:\n",
    "            return 'cardio'\n",
    "    return 'rest_light'  # Default\n",
    "\n",
    "# Apply logic to create target labels\n",
    "df['workout_type'] = df.apply(assign_workout, axis=1)\n",
    "\n",
    "# Save dataset to CSV for reuse\n",
    "df.to_csv('fitness_dataset.csv', index=False)\n",
    "\n",
    "# Display dataset info\n",
    "print(\"Dataset created with\", len(df), \"samples\")\n",
    "print(df.head())  # First 5 rows\n",
    "print(df['workout_type'].value_counts())  # Class distribution"
   ]
  },
